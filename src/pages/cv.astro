---
import { works } from '../constants/works';
import { educations } from '../constants/educations';
import { CONTACT_INFO } from '../constants/contact';

const techWorks = works.filter(w => w.stack?.length);

const skillGroups = [
  { label: 'Frontend', items: ['HTML', 'CSS', 'Sass', 'Less', 'Tailwind', 'Bootstrap'] },
  { label: 'JavaScript', items: ['JavaScript', 'TypeScript', 'React', 'Next.js', 'jQuery'] },
  { label: 'Backend', items: ['Node.js', 'Express', 'PHP', 'Laravel'] },
  { label: 'Databases', items: ['MySQL', 'MariaDB', 'MongoDB', 'PostgreSQL'] },
  { label: 'Tools', items: ['Git', 'Sequelize'] },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Agustín Arenas — Curriculum Vitae</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --accent:      #7c5cbf;
        --accent-dark: #5e3fa3;
        --accent-bg:   #ede9f8;
        --page-bg:     #ffffff;
        --shell-bg:    #dcdae8;
        --sidebar-bg:  #f5f3fd;
        --text:        #1a1525;
        --text-2:      #5c5a6e;
        --text-3:      #9997b0;
        --border:      rgba(124, 92, 191, 0.14);
        --border-2:    rgba(124, 92, 191, 0.22);
        --accent-glow: rgba(124, 92, 191, 0.2);
        --accent-grid: rgba(124, 92, 191, 0.025);
        --accent-dim:  rgba(124, 92, 191, 0.06);
        --accent-tag:  rgba(124, 92, 191, 0.18);
        --shadow:      rgba(60, 40, 120, 0.18);
        --sans:        'Space Grotesk', sans-serif;
        --mono:        'JetBrains Mono', monospace;
      }

      html, body {
        font-family: var(--sans);
        background: var(--shell-bg);
        color: var(--text);
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      /* ── PAGE SHELL ── */
      .page {
        width: 210mm;
        min-height: 297mm;
        margin: 2rem auto;
        background: var(--page-bg);
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 60px var(--shadow);
        position: relative;
        overflow: hidden;
      }

      /* subtle grid pattern (mirrors the portfolio body bg) */
      .page::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(var(--accent-grid) 1px, transparent 1px),
          linear-gradient(90deg, var(--accent-grid) 1px, transparent 1px);
        background-size: 24px 24px;
        pointer-events: none;
        z-index: 0;
      }

      .page > * { position: relative; z-index: 1; }

      /* ── HEADER ── */
      .cv-header {
        padding: 2.2rem 2.6rem 1.8rem 2.8rem;
        border-bottom: 1px solid var(--border-2);
        position: relative;
      }

      .cv-header-accent {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        background: linear-gradient(180deg, var(--accent), var(--accent-dark));
      }

      .cv-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 1.4rem;
      }

      .cv-name {
        font-size: 2.6rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1;
        color: var(--text);
      }

      .cv-role {
        margin-top: 0.5rem;
        font-family: var(--mono);
        font-size: 0.68rem;
        font-weight: 400;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .cv-role::before {
        content: '';
        display: block;
        width: 20px;
        height: 1px;
        background: var(--accent);
        flex-shrink: 0;
      }

      .cv-location {
        font-family: var(--mono);
        font-size: 0.65rem;
        color: var(--text-3);
        letter-spacing: 0.06em;
        margin-top: 1.4rem;
        background: var(--accent-bg);
        border: 1px solid var(--border-2);
        padding: 0.3rem 0.7rem;
        border-radius: 3px;
        align-self: flex-start;
        white-space: nowrap;
      }

      .cv-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 1.8rem;
      }

      .cv-contact-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--text-2);
        font-size: 0.78rem;
        text-decoration: none;
        font-family: var(--mono);
        letter-spacing: 0.01em;
      }

      .cv-contact-item svg {
        width: 11px;
        height: 11px;
        fill: var(--accent);
        flex-shrink: 0;
      }

      /* ── BODY ── */
      .cv-body {
        display: flex;
        flex: 1;
      }

      /* ── SIDEBAR ── */
      .cv-sidebar {
        width: 190px;
        min-width: 190px;
        background: var(--sidebar-bg);
        padding: 1.8rem 1.4rem;
        border-right: 1px solid var(--border-2);
        display: flex;
        flex-direction: column;
        gap: 1.6rem;
      }

      /* ── MAIN ── */
      .cv-main {
        flex: 1;
        padding: 1.8rem 2.2rem 1.8rem 2rem;
      }

      /* ── SECTION TITLE ── */
      .section-label {
        font-family: var(--mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        padding-bottom: 0.55rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border-2);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--border-2), transparent);
      }

      /* ── SKILL GROUPS ── */
      .skill-group {
        margin-bottom: 1rem;
      }

      .skill-group:last-child { margin-bottom: 0; }

      .skill-group-label {
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-3);
        font-family: var(--mono);
        margin-bottom: 0.45rem;
      }

      .skill-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
      }

      .skill-tag {
        font-family: var(--mono);
        font-size: 0.65rem;
        background: var(--accent-bg);
        color: var(--accent-dark);
        padding: 0.18rem 0.45rem;
        border-radius: 3px;
        border: 1px solid var(--accent-tag);
      }

      /* ── EDUCATION ITEMS ── */
      .edu-item {
        padding-bottom: 1rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }

      .edu-item:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
      }

      .edu-title {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.3;
      }

      .edu-subtitle {
        font-size: 0.7rem;
        color: var(--text-2);
        margin-top: 0.2rem;
        line-height: 1.3;
      }

      .edu-time {
        font-family: var(--mono);
        font-size: 0.63rem;
        color: var(--text-3);
        margin-top: 0.25rem;
      }

      /* ── EXPERIENCE ── */
      .work-item {
        position: relative;
        padding-left: 1.1rem;
        margin-bottom: 1.8rem;
      }

      .work-item:last-child { margin-bottom: 0; }

      .work-item::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.42rem;
        width: 6px;
        height: 6px;
        background: var(--accent);
        border-radius: 50%;
        box-shadow: 0 0 0 2px var(--accent-glow);
      }

      .work-item::after {
        content: '';
        position: absolute;
        left: 2.5px;
        top: 1.1rem;
        bottom: -1.1rem;
        width: 1px;
        background: linear-gradient(180deg, var(--border-2), transparent);
      }

      .work-item:last-child::after { display: none; }

      .work-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 0.25rem;
      }

      .work-company {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.01em;
      }

      .work-time {
        font-family: var(--mono);
        font-size: 0.62rem;
        color: var(--text-3);
        white-space: nowrap;
        flex-shrink: 0;
      }

      .work-title {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--accent);
        margin-bottom: 0.65rem;
        font-style: italic;
      }

      .work-responsibilities {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .work-responsibilities li {
        font-size: 0.78rem;
        color: var(--text-2);
        padding-left: 0.85rem;
        position: relative;
        line-height: 1.5;
      }

      .work-responsibilities li::before {
        content: '—';
        position: absolute;
        left: 0;
        color: var(--text-3);
        font-family: var(--mono);
        font-size: 0.7rem;
      }

      .work-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        margin-top: 0.65rem;
      }

      .work-stack-tag {
        font-family: var(--mono);
        font-size: 0.58rem;
        color: var(--text-3);
        background: var(--accent-dim);
        border: 1px solid var(--border);
        padding: 0.1rem 0.35rem;
        border-radius: 2px;
        letter-spacing: 0.04em;
      }

      /* ── SUMMARY ── */
      .cv-summary {
        font-size: 0.82rem;
        color: var(--text-2);
        line-height: 1.65;
        margin-bottom: 1.8rem;
        padding-bottom: 1.8rem;
        border-bottom: 1px solid var(--border);
      }

      /* ── PRINT ── */
      @media print {
        html, body { background: white; }

        .page {
          margin: 0;
          box-shadow: none;
          width: 100%;
          min-height: auto;
        }

        .page::before { display: none; }

        @page {
          margin: 12mm 14mm;
          size: A4;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">

      <!-- ── HEADER ── -->
      <header class="cv-header">
        <div class="cv-header-accent" aria-hidden="true"></div>

        <div class="cv-top">
          <div>
            <h1 class="cv-name">Agustín Arenas</h1>
            <p class="cv-role">Full-Stack Developer</p>
          </div>
          <span class="cv-location">Córdoba, Argentina</span>
        </div>

        <div class="cv-contact">
          <a href={`mailto:${CONTACT_INFO.email}`} class="cv-contact-item">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            {CONTACT_INFO.email}
          </a>

          <a href={CONTACT_INFO.linkedin} class="cv-contact-item">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
            linkedin/agustin-arenas
          </a>
          <a href={CONTACT_INFO.github} class="cv-contact-item">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
            ArenasAgustin
          </a>
          <a href={CONTACT_INFO.site} class="cv-contact-item">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16.36 14c.08-.66.14-1.32.14-2 0-.68-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2m-5.15 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 0 1-4.33 3.56M14.34 14H9.66c-.1-.66-.16-1.32-.16-2 0-.68.06-1.35.16-2h4.68c.09.65.16 1.32.16 2 0 .68-.07 1.34-.16 2M12 19.96c-.83-1.2-1.5-2.53-1.91-3.96h3.82c-.41 1.43-1.08 2.76-1.91 3.96M8 8H5.08A7.923 7.923 0 0 1 9.4 4.44C8.8 5.55 8.35 6.75 8 8m-2.92 8H8c.35 1.25.8 2.45 1.4 3.56A8.008 8.008 0 0 1 5.08 16m-.82-2C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2 0 .68.06 1.34.14 2M12 4.03c.83 1.2 1.5 2.54 1.91 3.97h-3.82c.41-1.43 1.08-2.77 1.91-3.97M18.92 8h-2.95a15.65 15.65 0 0 0-1.38-3.56c1.84.63 3.37 1.9 4.33 3.56M12 2C6.47 2 2 6.5 2 12a10 10 0 0 0 10 10 10 10 0 0 0 10-10A10 10 0 0 0 12 2z"/></svg>
            agustinarenas.vercel.app
          </a>
        </div>
      </header>

      <!-- ── BODY ── -->
      <div class="cv-body">

        <!-- ── SIDEBAR ── -->
        <aside class="cv-sidebar">

          <section>
            <h2 class="section-label">Skills</h2>
            {skillGroups.map(group => (
              <div class="skill-group">
                <p class="skill-group-label">{group.label}</p>
                <div class="skill-list">
                  {group.items.map(skill => (
                    <span class="skill-tag">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
          </section>

          <section>
            <h2 class="section-label">Education</h2>
            {educations.map(edu => (
              <div class="edu-item">
                <p class="edu-title">{edu.title}</p>
                <p class="edu-subtitle">{edu.subtitle}</p>
                <p class="edu-time">{edu.time}</p>
              </div>
            ))}
          </section>

        </aside>

        <!-- ── MAIN ── -->
        <main class="cv-main">

          <p class="cv-summary">
            Full-Stack Developer with 3+ years of professional experience building and maintaining scalable web products.
            Focused on performance, clean code, and pragmatic solutions from frontend to backend.
            Experienced across the full stack: React, Next.js, Node.js, PHP/Laravel, and relational/non-relational databases.
          </p>

          <section>
            <h2 class="section-label">Experience</h2>

            {techWorks.map(work => (
              <article class="work-item">
                <div class="work-header">
                  <span class="work-company">{work.subtitle}</span>
                  <span class="work-time">{work.time}</span>
                </div>
                <p class="work-title">{work.title}</p>
                {work.responsibilities && (
                  <ul class="work-responsibilities">
                    {work.responsibilities.map(r => (
                      <li>{r}</li>
                    ))}
                  </ul>
                )}
                {work.stack && (
                  <div class="work-stack">
                    {work.stack.map(tech => (
                      <span class="work-stack-tag">{tech}</span>
                    ))}
                  </div>
                )}
              </article>
            ))}
          </section>

        </main>
      </div>
    </div>
  </body>
</html>
