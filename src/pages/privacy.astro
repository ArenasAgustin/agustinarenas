---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout
  title="Privacy Policy | Agustín Arenas"
  description="Privacy policy for agustinarenas.vercel.app - Learn how your data is handled."
  robots="index, follow"
>
  <main id="main-content" tabindex="-1">
    <section class="section">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }]} />

      <div class="section-header">
        <span class="section-num">[ 00 ]</span>
        <h1 class="section-title">Privacy Policy</h1>
        <div class="section-line"></div>
      </div>

      <div class="policy-content">
        <p class="policy-date">Last updated: June 2026</p>

        <h2>Introduction</h2>
        <p>
          This Privacy Policy describes how Agustín Arenas ("I", "me", or "my") handles your information
          when you visit my portfolio website at agustinarenas.vercel.app (the "Site").
        </p>

        <h2>Information I Collect</h2>
        <p>
          This Site is a static portfolio website. I do not collect, store, or process any personal
          data from visitors. The Site does not:
        </p>
        <ul>
          <li>Use cookies or similar tracking technologies</li>
          <li>Store any user accounts or login information</li>
          <li>Collect form submissions (contact links open your email client directly)</li>
          <li>Use analytics that track individual users</li>
        </ul>

        <h2>Third-Party Services</h2>
        <p>This Site uses the following third-party services:</p>
        <ul>
          <li>
            <strong>Vercel</strong> — Hosting provider. Their privacy policy applies to their services.
<a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer">
              Vercel Privacy Policy
            </a>
          </li>
          <li>
            <strong>Google Fonts</strong> — Font delivery. Fonts are loaded from Google's servers.
            <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">
              Google Privacy Policy
            </a>
          </li>
        </ul>

        <h2>Links to External Sites</h2>
        <p>
          This Site contains links to external sites (GitHub, LinkedIn, project URLs). I am not
          responsible for the privacy practices of these external sites. I recommend reviewing their
          privacy policies before providing any personal information.
        </p>

        <h2>Changes to This Policy</h2>
        <p>
          I may update this Privacy Policy from time to time. Any changes will be posted on this page
          with an updated "Last updated" date.
        </p>

        <h2>Contact</h2>
        <p>
          If you have any questions about this Privacy Policy, please contact me at:
 </p>
        <ul>
          <li>Email: <a href="mailto:arenasagustin7@gmail.com">arenasagustin7@gmail.com</a></li>
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
  .policy-content {
    max-width: 720px;
  }

  .policy-date {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--fg2);
    margin-bottom: 2rem;
  }

  .policy-content h2 {
    font-size: 20px;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--fg);
  }

  .policy-content h2:first-of-type {
    margin-top: 0;
  }

  .policy-content p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--fg2);
    margin-bottom: 1rem;
  }

  .policy-content ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .policy-content li {
    font-size: 15px;
    line-height: 1.75;
    color: var(--fg2);
    margin-bottom: 0.5rem;
  }

  .policy-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .policy-content a:hover {
    color: var(--accent2);
  }

  .policy-content strong {
    color: var(--fg);
  }
</style>
