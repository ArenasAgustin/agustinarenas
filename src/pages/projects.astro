---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/sections/projects/Hero.astro";
import ProjectsSection from "@/sections/projects/ProjectsSection.astro";
import { CONTACT_INFO } from "@/constants/contact";
import { projects } from "@/constants/projects";

const projectsSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": `${CONTACT_INFO.site}/projects#collection`,
      name: "Agustín Arenas - Projects",
      description:
        "Portfolio of web development projects including Brain Games, Wave Music, and more",
      url: `${CONTACT_INFO.site}/projects`,
      datePublished: "2024-04-22",
      dateModified: new Date().toISOString().split("T")[0],
      isPartOf: {
        "@id": `${CONTACT_INFO.site}#website`,
      },
      author: {
        "@type": "Person",
        name: "Agustín Arenas",
      },
      mainEntity: {
        "@id": `${CONTACT_INFO.site}/projects#itemlist`,
      },
    },
    {
      "@type": "ItemList",
      "@id": `${CONTACT_INFO.site}/projects#itemlist`,
      name: "Software projects",
      itemListElement: projects.map((project, index) => ({
        "@type": "ListItem",
        position: index + 1,
        url: project.deployedUrl ?? project.repositoryUrl ?? null,
        item: {
          "@id": `${CONTACT_INFO.site}/projects#${project.id}`,
        },
      })),
    },
    ...projects.map((project) => ({
      "@type": "CreativeWork",
      "@id": `${CONTACT_INFO.site}/projects#${project.id}`,
      name: project.name,
      description: project.description,
      url: project.deployedUrl ?? project.repositoryUrl ?? null,
      creator: {
        "@type": "Person",
        name: "Agustín Arenas",
      },
      keywords: project.technologies.join(", "),
      codeRepository: project.repositoryUrl ?? null,
    })),
  ],
};
---

<Layout
  title="Agustín Arenas | My projects"
  description="Explore my web development projects built with TypeScript, React, Node.js, MongoDB, and modern web technologies. Including Brain Games, Wave Music, and more."
  image="/img/meta-projects.webp"
  schema={projectsSchema}
>
  <Hero />

  <ProjectsSection />
</Layout>
