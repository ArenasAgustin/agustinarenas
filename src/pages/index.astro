---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/sections/home/Hero.astro";
import About from "@/sections/home/About.astro";
import Portfolio from "@/sections/home/Portfolio.astro";
import Contact from "@/sections/home/Contact.astro";
import { CONTACT_INFO } from "@/constants/contact";

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${CONTACT_INFO.site}#webpage`,
      "url": CONTACT_INFO.site,
      "name": "Agustín Arenas | Software Developer",
      "description": "Full-Stack Developer from Argentina. Experienced in JavaScript, TypeScript, React, Node.js, and modern web technologies.",
      "isPartOf": { "@id": `${CONTACT_INFO.site}#website` },
      "about": { "@id": `${CONTACT_INFO.site}#person` },
    },
  ],
};
---

<Layout
  title="Agustín Arenas | Software Developer"
  description="Full-Stack Developer from Argentina. Experienced in JavaScript, TypeScript, React, Node.js, and modern web technologies. View my portfolio and projects."
  image="/img/meta-home.webp"
  schema={homeSchema}
>
  <Hero />

  <About />

  <Portfolio />

  <Contact />
</Layout>
