---
import Layout from '../layouts/Layout.astro';
import Hero from '../sections/index/Hero.astro';
import About from '../sections/index/About.astro';
import Experience from '../sections/index/Experience.astro';
import Skills from '../sections/index/Skills.astro';
import Projects from '../sections/index/Projects.astro';
import Contact from '../sections/index/Contact.astro';
import { CONTACT_INFO } from '../constants/contact';

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${CONTACT_INFO.site}#webpage`,
      "url": CONTACT_INFO.site,
      "name": "Agustín Arenas | Software Developer",
      "description": "Full-Stack Developer from Argentina. Experienced in JavaScript, TypeScript, React, Node.js, and modern web technologies.",
      "isPartOf": { "@id": `${CONTACT_INFO.site}#website` },
      "about": { "@id": `${CONTACT_INFO.site}#person` },
    },
  ],
};
---

<Layout
  title="Agustín Arenas — Software Developer"
  description="Full-Stack Developer based in Argentina. Building scalable web products with TypeScript, React, Node.js, and more."
  image="/img/meta-home.webp"
  schema={homeSchema}
>
  <main id="main-content" tabindex="-1">
    <Hero />
    <About />
    <Experience />
    <Skills />
    <Projects />
    <Contact />
  </main>
</Layout>
