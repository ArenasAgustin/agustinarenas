---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/sections/about/Hero.astro";
import Education from "@/sections/about/Education.astro";
import Works from "@/sections/about/Works.astro";
import Skills from "@/sections/about/Skills.astro";
import { CONTACT_INFO } from "@/constants/contact";

const aboutSchema = {
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": `${CONTACT_INFO.site}/about#page`,
      "url": `${CONTACT_INFO.site}/about`,
      "isPartOf": { "@id": `${CONTACT_INFO.site}#website` },
      "mainEntity": { "@id": `${CONTACT_INFO.site}#person` },
    },
  ],
};
---

<Layout
  title="About Agustín Arenas | Full-Stack Developer"
  description="Learn about my work experience at Dequo, education at Universidad Nacional de La Matanza, and technical skills in JavaScript, TypeScript, React, Node.js, and more."
  image="/img/meta-about.webp"
  schema={aboutSchema}
>
  <Hero />

  <Works />

  <Education />

  <Skills />
</Layout>
