---
import ContactIcon from "@/components/Icons/ContactIcon.astro";
import MobileIcon from "@/components/Icons/MobileIcon.astro";
import Link from "@/components/Links/Link.astro";
import Section from "@/components/Section/Section.astro";
import { CONTACT_INFO } from "@/constants/contact";
---

<Section title="Contact" id="contact">
  <div class="flex justify-center items-stretch flex-wrap p-4 md:space-x-9">
    <div class="flex flex-col justify-center items-center">
      <div
        class="p-1 md:p-2 relative transition-all duration-400 place-items-center *:size-7 md:*:size-9 *:stroke-2 *:transition-all *:duration-400 rounded-md hover:text-tradewind-500 hover:bg-mine-shaft-300/40 dark:hover:bg-mine-shaft-700/40 min-h-7 min-w-7 md:min-h-9 md:min-w-9"
        aria-hidden="true"
      >
        <ContactIcon />
      </div>
      <Link
        href={`mailto:${CONTACT_INFO.email}`}
        ariaLabel="Send email to Agustín Arenas">{CONTACT_INFO.email}</Link
      >
    </div>

    <div class="flex-center-center flex-col">
      <div
        class="p-1 md:p-2 relative transition-all duration-400 place-items-center *:size-7 md:*:size-9 *:stroke-2 *:transition-all *:duration-400 rounded-md hover:text-tradewind-500 hover:bg-mine-shaft-300/40 dark:hover:bg-mine-shaft-700/40 min-h-7 min-w-7 md:min-h-9 md:min-w-9"
        aria-hidden="true"
      >
        <MobileIcon />
      </div>
      <Link
        href={CONTACT_INFO.whatsapp}
        ariaLabel="Contact via WhatsApp"
        targetBlank={true}
      >
        +54 9 351-7738914
      </Link>
    </div>
  </div>
</Section>
