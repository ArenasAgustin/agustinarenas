---
import Section from "@/components/Section/Section.astro";
import LinkButton from "@/components/Links/LinkButton.astro";
import { Image } from "astro:assets";
import profileImg from "@/assets/profile.webp";
---

<Section title="About me" id="about">
  <div class="w-full flex-center-center flex-wrap mt-7">
    <Image
      src={profileImg}
      alt="Agustín Arenas profile photo"
      loading="lazy"
      class="rounded-md size-64 md:mr-20 object-cover aspect-square"
      widths={[240, 540, 720, profileImg.width]}
      sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px, ${profileImg.width}px`}
    />

    <div class="flex flex-col justify-center items-start m-6 md:m-0 md:ml-20">
      <p class="w-full max-w-xl mb-5 text-base md:text-base leading-relaxed">
        I am a Full-Stack Developer focused on solving real product problems with
        clean, scalable web solutions.
      </p>
      <p class="w-full max-w-lg mb-5 text-base md:text-base leading-relaxed">
        Based in Argentina, I work across frontend and backend development with a
        strong focus on performance, maintainability, and user experience.
      </p>
      <div class="flex space-x-4">
        <LinkButton
          href="/curriculum/Curriculum_Agustin_Arenas.pdf"
          ariaLabel="Download Agustín Arenas curriculum vitae (opens in new tab)"
          targetBlank={true}>Download CV</LinkButton
        >
        <LinkButton href="/about" ariaLabel="Read more about Agustín Arenas">Read more</LinkButton>
      </div>
    </div>
  </div>
</Section>
