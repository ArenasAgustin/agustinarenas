---
---

<section id="about-section">
  <div class="section">
    <div class="section-header reveal">
      <span class="section-num">[ 01 ]</span>
      <h2 class="section-title">About</h2>
      <div class="section-line"></div>
    </div>
    <div class="about-grid">
      <div>
        <p class="about-text reveal">
          I'm a <strong>Full-Stack Developer</strong> focused on solving real product problems with
          clean, scalable web solutions. Based in Argentina, I work across frontend and backend
          development with a strong focus on <strong>performance, maintainability, and user experience</strong>.
        </p>
      </div>
      <dl class="about-stats reveal reveal-delay-2">
        <div class="stat-cell">
          <dt class="stat-label">Full-Stack focus</dt>
          <dd class="stat-num">FS</dd>
        </div>
        <div class="stat-cell">
          <dt class="stat-label">Years coding</dt>
          <dd class="stat-num">3+</dd>
        </div>
        <div class="stat-cell">
          <dt class="stat-label">Based in Córdoba</dt>
          <dd class="stat-num">ARG</dd>
        </div>
        <div class="stat-cell">
          <dt class="stat-label">Technologies</dt>
          <dd class="stat-num">10+</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .about-text {
    font-size: 16px;
    line-height: 1.8;
    color: var(--fg2);
    margin-bottom: 32px;
  }
  .about-text strong { color: var(--fg); }
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .stat-cell {
    padding: 28px 24px;
    background: var(--bg);
  }
  @media (prefers-reduced-motion: no-preference) {
    .stat-cell {
      transition: background 0.2s;
    }
  }
  .stat-cell:hover { background: var(--surface); }
  .stat-num {
    font-family: var(--mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--fg2);
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
