---
import { skills } from '../../constants/skills';

// Size weights — xl=most used, sm=least
const sizeMap: Record<string, string> = {
  'JavaScript':  'sc-xl',
  'React':       'sc-xl',
  'TypeScript':  'sc-lg',
  'Next.js':     'sc-lg',
  'Laravel':     'sc-lg',
  'Tailwind':    'sc-lg',
  'Node.js':     'sc-md',
  'PHP':         'sc-md',
  'PostgreSQL':  'sc-md',
  'Express':     'sc-md',
  'MongoDB':     'sc-md',
  'Git':         'sc-md',
};

function sizeClass(skill: string): string {
  return sizeMap[skill] ?? 'sc-sm';
}
---

<section id="skills-section">
  <div class="section">
    <div class="section-header reveal">
      <span class="section-num">[ 03 ]</span>
      <h2 class="section-title">Skills</h2>
      <div class="section-line"></div>
    </div>
    <ul role="list" class="skills-cloud reveal">
      {skills.map(skill => (
        <li class={`sc-tag ${sizeClass(skill)}`}>{skill}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  #skills-section {
    border-top: 1px solid var(--border);
  }
  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 16px;
    align-items: center;
    padding: 48px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg2);
    list-style: none;
    margin: 0;
  }
  .sc-tag {
    font-family: var(--mono);
    font-weight: 600;
    color: var(--fg);
    opacity: 0.9;
    cursor: default;
    transition: color 0.2s, opacity 0.2s, transform 0.2s;
    line-height: 1;
  }
  .sc-tag:hover {
    color: var(--accent);
    opacity: 1;
    transform: scale(1.08);
  }
  .sc-xl { font-size: 36px; letter-spacing: -0.02em; }
  .sc-lg { font-size: 24px; letter-spacing: -0.01em; color: var(--fg2); }
  .sc-md { font-size: 17px; color: var(--fg2); }
  .sc-sm { font-size: 13px; color: var(--fg2); }

  @media (max-width: 768px) {
    .skills-cloud { padding: 28px 20px; }
    .sc-xl { font-size: 28px; }
    .sc-lg { font-size: 20px; }
  }
</style>
