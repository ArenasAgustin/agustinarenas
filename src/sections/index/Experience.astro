---
import { works } from '../../constants/works';
---

<section id="experience-section">
  <div class="section">
    <div class="section-header reveal">
      <span class="section-num">[ 02 ]</span>
      <h2 class="section-title">Experience</h2>
      <div class="section-line"></div>
    </div>
    <div class="experience-list">
      {works.map((work, index) => (
        <div class={`exp-row reveal${['', ' reveal-delay-1', ' reveal-delay-2'][index % 3]}`}>
          <div class="exp-meta">
            <div class="exp-period">{work.time}</div>
            <div class="exp-company">{work.subtitle}</div>
          </div>
          <div class="exp-content">
            <div class="exp-role">{work.title}</div>
            <p class="exp-desc">{work.summary ?? work.description}</p>
            {work.stack && work.stack.length > 0 && (
              <div class="tags">
                {work.stack.map(tech => <span class="tag">{tech}</span>)}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .exp-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 40px;
    padding: 36px 40px;
    background: var(--bg);
    transition: background 0.2s;
  }
  .exp-row:hover { background: var(--surface); }
  .exp-meta { padding-top: 4px; }
  .exp-period {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }
  .exp-company {
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
  }
  .exp-role {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .exp-desc {
    font-size: 14px;
    color: var(--fg2);
    line-height: 1.65;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
  .tag {
    font-family: var(--mono);
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--fg2);
    background: var(--surface);
  }

  @media (max-width: 768px) {
    .exp-row { grid-template-columns: 1fr; gap: 12px; padding: 24px; }
  }
</style>
