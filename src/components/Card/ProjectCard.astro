---
import LinkButton from "@/components/Links/LinkButton.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import brainGameEs from "@/assets/brain_games_es.webp";
import waveMusic from "@/assets/wave_music.webp";
import blackParadox from "@/assets/blackparadox.webp";
import js_benchmark from "@/assets/js_benchmark.webp";
import morseDecoder from "@/assets/morse_decoder.webp";
import urlShortener from "@/assets/url_shortener.webp";
import cinema from "@/assets/cinema.webp";
import webdevTools from "@/assets/webtools.webp";
import defaultImage from "@/assets/profile.webp";

function getImage(id: string | undefined): ImageMetadata {
  switch (id) {
    case "brain_games_es":
      return brainGameEs;
    case "wave_music":
      return waveMusic;
    case "blackparadox":
      return blackParadox;
    case "js_benchmark":
      return js_benchmark;
    case "morse_decoder":
      return morseDecoder;
    case "url_shortener":
      return urlShortener;
    case "cinema":
      return cinema;
    case "webdev_tools":
      return webdevTools;
    default:
      if (id) throw new Error(`[ProjectCard] No image mapping for project id "${id}". Add it to getImage() or pass a valid id.`);
      return defaultImage;
  }
}

interface Props {
  name: string;
  description: string;
  technologies: string[];
  repositoryUrl?: string;
  deployedUrl?: string;
  id: string;
}

const { name, description, technologies, repositoryUrl, deployedUrl, id } =
  Astro.props;

const imageUrl = getImage(id);
const headingId = `${id}-title`;
---

<article
  aria-labelledby={headingId}
  class="max-w-sm mx-6 my-4 overflow-hidden shadow-box-inset rounded-lg flex flex-col hover-lift"
>
  <Image
    class="w-full h-52 object-cover"
    src={imageUrl}
    alt={`Screenshot of ${name}`}
    loading="lazy"
    widths={[240, 540, 720, imageUrl.width]}
    sizes={`(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw`}
  />

  <div class="px-6 py-4 flex-1">
    <h3 id={headingId} class="font-bold text-xl mb-2">{name}</h3>

    <p class="text-base line-clamp-4">
      {description}
    </p>

    <div class="mt-4">
      <p class="text-base">
        Technologies: {technologies.join(", ")}
      </p>
    </div>
  </div>

  <div class="w-full px-6 py-4 flex justify-center gap-4 mt-auto">
    {
      repositoryUrl && (
        <LinkButton
          href={repositoryUrl}
          ariaLabel={`View source code for ${name}`}
          targetBlank={true}
          extraClass="flex-1 text-center whitespace-nowrap"
        >
          Source code
        </LinkButton>
      )
    }

    {
      deployedUrl && (
        <LinkButton
          href={deployedUrl}
          ariaLabel={`View live demo of ${name}`}
          targetBlank={true}
          extraClass="flex-1 text-center whitespace-nowrap"
        >
          Live demo
        </LinkButton>
      )
    }
  </div>
</article>
