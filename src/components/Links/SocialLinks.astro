---
import LinkIcon from "@/components/Links/LinkIcon.astro";
import LinkedinIcon from "@/components/Icons/LinkedinIcon.astro";
import GithubIcon from "@/components/Icons/GithubIcon.astro";
import ContactIcon from "@/components/Icons/ContactIcon.astro";
import CvIcon from "@/components/Icons/CvIcon.astro";
import { CONTACT_INFO } from "@/constants/contact";
---

<div class="flex-center-center">
  <LinkIcon href={CONTACT_INFO.github} ariaLabel="Visit Agustín Arenas on GitHub">
    <GithubIcon />
  </LinkIcon>

  <LinkIcon href={CONTACT_INFO.linkedin} ariaLabel="Visit Agustín Arenas on LinkedIn">
    <LinkedinIcon />
  </LinkIcon>

  <LinkIcon
    href={`mailto:${CONTACT_INFO.email}`}
    ariaLabel="Send email to Agustín Arenas"
    targetBlank={false}
  >
    <ContactIcon />
  </LinkIcon>

  <LinkIcon href={CONTACT_INFO.cv} ariaLabel="Download CV (PDF, opens in new tab)">
    <CvIcon />
  </LinkIcon>
</div>
