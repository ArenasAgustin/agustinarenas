---
import Link from "./Link.astro";

interface Props {
  href: string;
  ariaLabel: string;
  targetBlank?: boolean;
  extraClass?: string;
}

const { href, ariaLabel, targetBlank = false, extraClass = "" } = Astro.props;
---

<Link
  href={href}
  ariaLabel={ariaLabel}
  targetBlank={targetBlank}
  extraClass={`bg-tradewind-600 px-4 py-2 rounded-3xl cursor-pointer font-semibold text-white transition-all duration-400 hover:-translate-y-px hover:bg-tradewind-500 mx-0 my-0 ${extraClass}`}
>
  <slot />
</Link>
