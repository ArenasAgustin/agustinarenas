---
import Dark from "@/components/Icons/DarkIcon.astro";
import Light from "@/components/Icons/LightIcon.astro";
---

<div class="text-xl" id="themeToggle">
    <button
        type="button"
        class="relative place-items-center *:size-5 md:*:size-7 *:stroke-2 after:absolute after:h-0.5 after:-bottom-0.5 after:left-0 after:bg-mine-shaft-900 dark:after:bg-mine-shaft-100 after:w-0 hover:after:w-full after:transition-all after:duration-300 bg-transparent border-none cursor-pointer p-1 md:p-2 rounded min-h-7 min-w-7 md:min-h-9 md:min-w-9"
        aria-label="Toggle dark/light theme"
    >
        <Dark />
        <Light />
    </button>

    <script>
        let controller: AbortController | null = null;

        // astro:before-swap: abort controller to clean up click listeners before next navigation.
        // Theme class preservation is handled by theme-init.js (external script, no CSP hash needed).
        document.addEventListener("astro:before-swap", () => {
            controller?.abort();
        });

        document.addEventListener("astro:page-load", () => {
            controller = new AbortController();
            const { signal } = controller;

            // Query all toggle buttons (supports multiple ToggleTheme instances on the page)
            const buttons = document.querySelectorAll<HTMLButtonElement>(
                "#themeToggle button",
            );

            const handleToggleClick = () => {
                const element = document.documentElement;
                element.classList.toggle("dark");

                const isDark = element.classList.contains("dark");
                localStorage.setItem("theme", isDark ? "dark" : "light");

                // Update aria-label on all toggle buttons
                document
                    .querySelectorAll<HTMLButtonElement>("#themeToggle button")
                    .forEach((btn) => {
                        btn.setAttribute(
                            "aria-label",
                            isDark
                                ? "Switch to light theme"
                                : "Switch to dark theme",
                        );
                    });
            };

            buttons.forEach((button) => {
                button.addEventListener("click", handleToggleClick, {
                    signal,
                });

                // Set correct initial aria-label
                const isDark =
                    document.documentElement.classList.contains("dark");
                button.setAttribute(
                    "aria-label",
                    isDark ? "Switch to light theme" : "Switch to dark theme",
                );
            });
        });
    </script>
</div>
