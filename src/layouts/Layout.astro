---
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import { CONTACT_INFO } from "@/constants/contact";
import EventController from "@/components/utils/EventController.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  schema?: Record<string, unknown>;
  robots?: string;
}

const {
  title = "Agustín Arenas — Software Developer",
  description = "Personal portfolio of Agustín Arenas, a Full-Stack Developer focused on building fast, reliable, and maintainable web products.",
  image = "/img/meta-home.webp",
  imageAlt = "Agustín Arenas — Full-Stack Developer portfolio preview",
  schema,
  robots = "index, follow",
} = Astro.props;

const baseURL = Astro.site ?? new URL('https://agustinarenas.vercel.app');
const canonicalURL = new URL(Astro.url.pathname, baseURL);
const ogImageURL = new URL(image, baseURL);

const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${baseURL}#person`,
      name: "Agustín Arenas",
      url: baseURL,
      image: `${baseURL}/img/meta-home.webp`,
      jobTitle: "Software Developer",
      description:
        "Full-Stack Developer with expertise in web development, problem-solving, and open-source contributions",
      sameAs: [CONTACT_INFO.github, CONTACT_INFO.linkedin],
      knowsAbout: [
        "JavaScript",
        "TypeScript",
        "React",
        "Node.js",
        "HTML",
        "CSS",
        "Sass",
        "Tailwind CSS",
        "MongoDB",
        "MySQL",
        "PostgreSQL",
      ],
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "Universidad Nacional de La Matanza",
      },
      nationality: {
        "@type": "Country",
        name: "Argentina",
      },
    },
    {
      "@type": "WebSite",
      "@id": `${baseURL}#website`,
      name: "Agustín Arenas Portfolio",
      url: baseURL,
      inLanguage: "en",
      datePublished: "2024-04-22",
      publisher: {
        "@id": `${baseURL}#person`,
      },
    },
  ],
};
---

<!doctype html>
<html lang="en" id="site-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" id="theme-color-meta" content="#08080e">
    <meta name="color-scheme" content="light dark">
    <script is:inline>(function () {
  try {
    var root = document.documentElement;
    var stored = localStorage.getItem('theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    var isDark = stored ? stored === 'dark' : prefersDark;
    if (!isDark) {
      root.dataset.theme = 'light';
    }
    var metaThemeColor = document.getElementById('theme-color-meta');
    if (metaThemeColor) metaThemeColor.setAttribute('content', isDark ? '#08080e' : '#f5f4fa');
  } catch (e) { console.warn('[theme] Failed to read theme preference:', e); }
})();</script>

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      integrity="sha384-bZDMSjDeddChvQlX2wHcxdZrpNxo39rnBPQpe/jP4iuFgiKzONOGQfRKX+fSENr2"
      crossorigin="anonymous"
      onload="this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>
    <meta name="author" content="Agustín Arenas" />
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Agustín Arenas Portfolio" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1899" />
    <meta property="og:image:height" content="949" />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="bingbot" content={robots} />

    <link rel="preload" as="image" href="/img/meta-home.webp" fetchpriority="high" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify((() => {
        const mergedSchema = schema
          ? {
              "@context": "https://schema.org",
              "@graph": [
                ...(baseSchema["@graph"] as unknown[]),
                ...((schema["@graph"] as unknown[]) ?? [schema]),
              ],
            }
          : baseSchema;
        return mergedSchema;
      })())
        .replace(/</g, '\\u003c')
        .replace(/>/g, '\\u003e')
        .replace(/&/g, '\\u0026')}
    />

    <meta name="generator" content={Astro.generator} />

    {import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
      <meta
        name="google-site-verification"
        content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION}
      />
    )}

    <ClientRouter />

    <script>
      function initLayout() {
        const main = document.getElementById('main-content');
        if (main) main.focus();
      }

      document.addEventListener('astro:after-swap', initLayout);
    </script>
  </head>

  <body>
    <EventController key="layout">
      <a href="#main-content" class="sr-only">Skip to main content</a>
      <Nav />

      <slot />
      <Footer />
    </EventController>

    <script type="speculationrules">
      {
        "prefetch": [
          {
            "source": "document",
            "where": { "href_matches": "/**" },
            "eagerness": "moderate"
          }
        ]
      }
    </script>

    <script>
      function initReveal() {
        let revealObserver: IntersectionObserver | null = null;

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(el => {
            if (el.isIntersecting) {
              el.target.classList.add('visible');
              revealObserver?.unobserve(el.target);
            }
          });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => revealObserver!.observe(el));
        document.addEventListener('astro:before-swap', () => {
          revealObserver?.disconnect();
          revealObserver = null;
        });
      }
      document.addEventListener('astro:page-load', initReveal);
    </script>

  </body>
</html>
