---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SnowFlakes from "@/components/SnowFlakes.astro";
import ScrollToTop from "@/components/Buttons/ScrollToTop.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import "@/styles/stars.css";
import { CONTACT_INFO } from "@/constants/contact";

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
}

const {
  title = "Agustín Arenas | Software Developer",
  description = "Personal portfolio of Agustín Arenas, a Full-Stack Developer focused on building fast, reliable, and maintainable web products.",
  image = "/img/meta-home.webp",
  schema,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || CONTACT_INFO.site,
);
const ogImageURL = new URL(image, Astro.site || CONTACT_INFO.site);

const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${CONTACT_INFO.site}#person`,
      name: "Agustín Arenas",
      url: CONTACT_INFO.site,
      image: `${CONTACT_INFO.site}/img/meta-home.webp`,
      jobTitle: "Software Developer",
      description:
        "Full-Stack Developer with expertise in web development, problem-solving, and open-source contributions",
      sameAs: [CONTACT_INFO.github, CONTACT_INFO.linkedin],
      knowsAbout: [
        "JavaScript",
        "TypeScript",
        "React",
        "Node.js",
        "HTML",
        "CSS",
        "Sass",
        "Tailwind CSS",
        "MongoDB",
        "MySQL",
        "PostgreSQL",
      ],
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "Universidad Nacional de La Matanza",
      },
      nationality: {
        "@type": "Country",
        name: "Argentina",
      },
    },
    {
      "@type": "WebSite",
      "@id": `${CONTACT_INFO.site}#website`,
      name: "Agustín Arenas Portfolio",
      url: CONTACT_INFO.site,
      inLanguage: "en",
      datePublished: "2024-04-22",
      dateModified: new Date().toISOString().split("T")[0],
      publisher: {
        "@id": `${CONTACT_INFO.site}#person`,
      },
    },
  ],
};
---

<!doctype html>
<html lang="en" class="w-full scroll-smooth">
  <head>
    <script is:inline src="/theme-init.js"></script>

    <link
      rel="preload"
      href="/font/junction-regular.woff"
      as="font"
      type="font/woff"
      crossorigin
    />

    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="og:site_name" content="Agustín Arenas Portfolio" />
    <meta name="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content={title} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    <meta property="twitter:image:alt" content={title} />

    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#262626" />

    <meta
      name="keywords"
      content="portfolio, full-stack, frontend, backend, web, developer, programmer, agustin arenas"
    />

    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema || baseSchema)}
    />

    <meta name="generator" content={Astro.generator} />

    <meta
      name="google-site-verification"
      content="t_1n_26BmkF-2xZ7g3j_xYF-eaDDOxWk8g_EBzW5tuw"
    />

    <ClientRouter fallback="none" />
    <script>
      // Prefetch pages on hover for faster navigation
      document.addEventListener("astro:page-load", () => {
        const prefetchableLinks = document.querySelectorAll(
          'a[data-astro-prefetch="hover"]',
        );
        prefetchableLinks.forEach((link) => {
          link.addEventListener("mouseenter", () => {
            const href = link.getAttribute("href");
            if (
              href &&
              !document.querySelector(`link[rel="prefetch"][href="${href}"]`)
            ) {
              const prefetchLink = document.createElement("link");
              prefetchLink.rel = "prefetch";
              prefetchLink.href = href;
              document.head.appendChild(prefetchLink);
            }
          });
        });
      });
    </script>
  </head>

  <body
    class="relative w-full min-h-screen overflow-x-hidden background-image bg-mine-shaft-100 text-mine-shaft-900 dark:bg-mine-shaft-900 dark:text-mine-shaft-100 font-junction scrollbar transition-all duration-300 *:transition-all *:duration-300"
  >
    <Header />

    <main class="flex-center-center flex-col w-full">
      <slot />
    </main>

    <Footer />

    <div class="starsContainer">
      <div class="stars"></div>
      <div class="stars2"></div>
      <div class="stars3"></div>
    </div>

    <SnowFlakes />
    <ScrollToTop />
  </body>
</html>
