---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SnowFlakes from "@/components/SnowFlakes.astro";
import ScrollToTop from "@/components/Buttons/ScrollToTop.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import "@/styles/stars.css";
import { CONTACT_INFO } from "@/constants/contact";

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
}

const {
  title = "Agustín Arenas | Software Developer",
  description = "Personal portfolio of Agustín Arenas, a Full-Stack Developer focused on building fast, reliable, and maintainable web products.",
  image = "/img/meta-home.webp",
  schema,
} = Astro.props;

const baseURL = Astro.site ?? CONTACT_INFO.site ?? "https://agustinarenas.vercel.app";
const canonicalURL = new URL(Astro.url.pathname, baseURL);
const ogImageURL = new URL(image, baseURL);

const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${baseURL}#person`,
      name: "Agustín Arenas",
      url: baseURL,
      image: `${baseURL}/img/meta-home.webp`,
      jobTitle: "Software Developer",
      description:
        "Full-Stack Developer with expertise in web development, problem-solving, and open-source contributions",
      sameAs: [CONTACT_INFO.github, CONTACT_INFO.linkedin],
      knowsAbout: [
        "JavaScript",
        "TypeScript",
        "React",
        "Node.js",
        "HTML",
        "CSS",
        "Sass",
        "Tailwind CSS",
        "MongoDB",
        "MySQL",
        "PostgreSQL",
      ],
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "Universidad Nacional de La Matanza",
      },
      nationality: {
        "@type": "Country",
        name: "Argentina",
      },
    },
    {
      "@type": "WebSite",
      "@id": `${baseURL}#website`,
      name: "Agustín Arenas Portfolio",
      url: baseURL,
      inLanguage: "en",
      datePublished: "2024-04-22",
      publisher: {
        "@id": `${baseURL}#person`,
      },
    },
  ],
};
---

<!doctype html>
<html lang="en" class="w-full scroll-smooth" id="site-html">
  <head>
    <script is:inline src="/theme-init.js"></script>
    <script is:inline>
      (function () {
        // Preserve theme class across ViewTransitions swaps — guard prevents stacking N listeners
        if (!window.__themeSwapListenerAdded) {
          window.__themeSwapListenerAdded = true;
          document.addEventListener("astro:before-swap", function (event) {
            var currentTheme = document.documentElement.classList.contains("dark") ? "dark" : "";
            var newHtml = event.newDocument.documentElement;
            if (currentTheme) {
              newHtml.classList.add("dark");
            } else {
              newHtml.classList.remove("dark");
            }
          });
        }
      })();
    </script>

    <link
      rel="preload"
      href="/font/junction-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="author" content="Agustín Arenas" />
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Agustín Arenas Portfolio" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content={title} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    <meta property="twitter:image:alt" content={title} />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#262626" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#e7e7e7" media="(prefers-color-scheme: light)" />

    <meta
      name="keywords"
      content="portfolio, full-stack, frontend, backend, web, developer, programmer, agustin arenas"
    />

    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="msapplication-config" content="/browserconfig.xml" />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema ?? baseSchema).replace(/<\/script>/gi, "<\\/script>")}
    />

    <meta name="generator" content={Astro.generator} />

    {import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
      <meta
        name="google-site-verification"
        content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION}
      />
    )}

    <ClientRouter fallback="none" />
  </head>

  <body
    class="relative w-full min-h-screen overflow-x-hidden background-image bg-mine-shaft-100 text-mine-shaft-900 dark:bg-mine-shaft-900 dark:text-mine-shaft-100 font-junction scrollbar transition-all duration-300"
  >
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-mine-shaft-900 focus:text-mine-shaft-100 focus:px-4 focus:py-2 focus:rounded">Skip to main content</a>
    <Header />

    <main id="main-content" tabindex="-1" class="flex-center-center flex-col w-full">
      <slot />
    </main>

    <Footer />

    <div class="starsContainer">
      <div class="stars"></div>
      <div class="stars2"></div>
      <div class="stars3"></div>
    </div>

    <SnowFlakes />
    <ScrollToTop />
  </body>
</html>
