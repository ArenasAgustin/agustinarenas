{
    "headers": [
        {
            "source": "/(.*).(avif|webp|svg|png|jpg)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, stale-while-revalidate=120"
                }
            ]
        },
        {
            "source": "/(.*).(js|css)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*).woff",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; script-src 'self' 'sha256-i+vNIPZAyMgtZsfSXEjuByn0oDC4UQ3GO0LbLHXVcRc=' 'sha256-xM6MSr8d+gRVZi9dWOXJr20R+4O+8DVoluBwjomgBV0=' 'sha256-8aAegBHnh+FhJN/Q+/P1dAH5RVTIy0QtR+m6Mi57V7Q=' 'sha256-gZ8XHCnJSs/Khqy/Y1rML545BRQMVafX3z78OpQtNnQ='; img-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://vitals.vercel-insights.com;"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "same-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "geolocation=(), microphone=(), sync-xhr=(), midi=(), camera=(), magnetometer=(), gyroscope=(), speaker=(), fullscreen=(), payment=()"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000; includeSubDomains; preload"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Server",
                    "value": "vercel"
                }
            ]
        }
    ]
}